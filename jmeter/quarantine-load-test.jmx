          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Inject CSRF Headers">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">String token = vars.get(&quot;csrfToken&quot;);
if (token != null) {
    sampler.addHeader(&quot;X-XSRF-TOKEN&quot;, token);
}
sampler.addHeader(&quot;Accept&quot;, &quot;application/json&quot);</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PreProcessor>
