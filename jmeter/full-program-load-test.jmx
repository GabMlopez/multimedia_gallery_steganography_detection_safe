      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET CSRF (supervisor)" enabled="true">
          <stringProp name="HTTPSampler.domain">localhost</stringProp>
